@model IEnumerable<DA09_QLSK.Models.PhanLoaiSK>

    @{
    ViewData["Title"] = "Quản lý loại sự kiện";
    ViewData["Breadcrumb"] = new List<(string Title, string Url)>
        {
       
        ("Loại sự kiện", null)
        };
        int currentPage = (int)(ViewBag.Page ?? 1);
        int stt = (currentPage - 1) * 10 + 1;
        }

        <div class="container mt-4 mb-4">
            <partial name="_Breadcrumb" />

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Danh sách Loại sự kiện</h2>
                <a asp-controller="QuanLyLoai" asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Thêm Loại Sự Kiện
                </a>
            </div>

            <table class="table table-hover table-bordered">
                <thead class="thead-dark">
                    <tr>
                        <th>STT</th>
                        <th>Mã Loại</th>
                        <th>Tên Loại</th>
                        <th>Mô tả</th>
                        <th style="width: 120px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                    <tr>
                        <td>@(stt++)</td>
                        <td>@item.MaLoaiSK</td>
                        <td>@item.TenLoai</td>
                        <td>@item.MoTaLoaiSK</td>
                        <td>
                            @* Nut Xóa hiển thị Dialog *@
                            <div class="d-flex" style="gap: 5px;">
                                <a asp-controller="QuanLyLoai" asp-action="Edit" asp-route-id="@item.MaLoaiSK" class="btn btn-sm btn-warning">Sửa</a>
                                <button class="btn btn-sm btn-danger" onclick="openDeleteModal('@item.MaLoaiSK', '@item.TenLoai')">Xóa</button>
                            </div>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>

            <nav>
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= (int)(ViewBag.TotalPages ?? 1); i++)
                    {
                    <li class="page-item @(i == currentPage ? " active" : "" )">
                        <a class="page-link" asp-action="Admin_LoaiSK" asp-route-page="@i">@i</a>
                    </li>
                    }
                </ul>
            </nav>
        </div>

        <div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">Xác nhận xóa</h5></div>
                    <div class="modal-body">Bạn có chắc chắn muốn xóa loại sự kiện "<span id="delTenLoai" style="font-weight:bold;"></span>" không?</div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Không xóa</button>
                        <button type="button" class="btn btn-danger" onclick="confirmDelete()">Xóa</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="successModal" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">Thông báo</h5></div>
                    <div class="modal-body">Bạn đã xóa loại sự kiện "<span id="successTenLoai" style="font-weight:bold;"></span>" thành công!</div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-primary" onclick="location.reload()">Đóng</button>
                    </div>
                </div>
            </div>
        </div>

        @Html.AntiForgeryToken()

        @section Scripts {
        <script>
            //* Script Xử Lý Xóa Loại sự kiện
            let currentMaLoai = '';
            let currentTenLoai = '';

            function openDeleteModal(id, ten) {
                currentMaLoai = id;
                currentTenLoai = ten;
                document.getElementById('delTenLoai').innerText = ten;
                $('#deleteModal').modal('show');
            }

            function confirmDelete() {
                $.ajax({
                    url: '/QuanLyLoai/DeleteLoai',
                    type: 'POST',
                    data: {
                        id: currentMaLoai,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (res) {
                        if (res.success) {
                            $('#deleteModal').modal('hide');
                            document.getElementById('successTenLoai').innerText = currentTenLoai;
                            $('#successModal').modal('show');
                        } else {
                            alert('Lỗi: ' + res.message);
                        }
                    }
                });
            }
        </script>
        }
