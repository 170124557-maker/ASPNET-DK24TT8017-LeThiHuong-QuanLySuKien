@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="row">
    <div class="col-md-12">

        <div class="card my-4 bg-light border-0 shadow-sm">
            <div class="card-body d-flex justify-content-center align-items-center">

                <form method="get" action="@Url.Action("TimKiemChung", "Home")" class="form-inline d-flex justify-content-center w-100" style="gap: 10px;">

                    <div style="width: 100%; max-width: 550px;">
                        <input type="text" class="form-control w-100" id="searchEvent" name="tuKhoa" placeholder="Tìm kiếm Sự kiện theo Khoa, tên Sự kiện, Lĩnh vực" required>
                    </div>

                    <div>
                        <button type="submit" class="btn btn-primary px-4">Tìm Kiếm</button>
                    </div>

                </form>

            </div>
        </div>
        <div id="homeCarousel" class="carousel slide shadow rounded overflow-hidden" data-ride="carousel" data-interval="3000" style="background-color: #ffffff; position: relative;">

            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="~/HomeImage/slide1.jpg" class="d-block w-100" alt="Hình nền 1" style="height: 450px; object-fit: fill;">
                    <div class="carousel-caption d-none d-md-block" style="background: rgba(0,0,0,0.6); border-radius: 8px; max-width: 50%; left: 0; right: 0; margin: auto; padding: 15px; bottom: 30px;">
                        <h5 style="margin-bottom: 8px;">Trường Đại Học Nghệ Thuật Tp.HCM</h5>
                        <p class="mb-0" style="font-size: 14px;">Hệ thống thông tin quản lý sự kiện khoa học và nghệ thuật.</p>
                    </div>
                </div>

                <div class="carousel-item">
                    <img src="~/HomeImage/slide2.jpg" class="d-block w-100" alt="Hình nền 2" style="height: 450px; object-fit: fill;">
                    <div class="carousel-caption d-none d-md-block" style="background: rgba(0,0,0,0.6); border-radius: 8px; max-width: 50%; left: 0; right: 0; margin: auto; padding: 15px; bottom: 30px;">
                        <h5 style="margin-bottom: 8px;">Hoạt Động Phong Trào Thường Niên</h5>
                        <p class="mb-0" style="font-size: 14px;">Nơi sinh viên đăng ký tham gia, điểm danh và tích lũy điểm rèn luyện.</p>
                    </div>
                </div>

                <div class="carousel-item">
                    <img src="~/HomeImage/slide3.jpg" class="d-block w-100" alt="Hình nền 3" style="height: 450px; object-fit: fill;">
                    <div class="carousel-caption d-none d-md-block" style="background: rgba(0,0,0,0.6); border-radius: 8px; max-width: 50%; left: 0; right: 0; margin: auto; padding: 15px; bottom: 30px;">
                        <h5 style="margin-bottom: 8px;">Đồ Án Tốt Nghiệp Khóa 2019</h5>
                        <p class="mb-0" style="font-size: 14px;">Sinh viên thực hiện: Lê Thị Hương - Giảng viên hướng dẫn: Đoàn Phước Miền.</p>
                    </div>
                </div>
            </div>

            <a class="carousel-control-prev" href="#homeCarousel" role="button" data-slide="prev"
               style="width: 50px; height: 50px; background-color: #6c757d !important; top: 50%; transform: translateY(-50%); left: 5px; border-radius: 6px; opacity: 0.85;">
                <span class="carousel-control-prev-icon" aria-hidden="true" style="width: 25px; height: 25px;"></span>
                <span class="sr-only">Trước</span>
            </a>

            <a class="carousel-control-next" href="#homeCarousel" role="button" data-slide="next"
               style="width: 50px; height: 50px; background-color: #6c757d !important; top: 50%; transform: translateY(-50%); right: 5px; border-radius: 6px; opacity: 0.85;">
                <span class="carousel-control-next-icon" aria-hidden="true" style="width: 25px; height: 25px;"></span>
                <span class="sr-only">Sau</span>
            </a>

            <div class="py-2" style="background-color: #f1f3f5; border-top: 1px solid #dee2e6;">
                <ol class="carousel-indicators" style="position: static; margin: 0; justify-content: center;">
                    <li data-target="#homeCarousel" data-slide-to="0" class="active" style="background-color: #007bff; width: 30px; height: 5px;"></li>
                    <li data-target="#homeCarousel" data-slide-to="1" style="background-color: #6c757d; width: 30px; height: 5px;"></li>
                    <li data-target="#homeCarousel" data-slide-to="2" style="background-color: #6c757d; width: 30px; height: 5px;"></li>
                </ol>
            </div>

        </div>

    </div>
</div>