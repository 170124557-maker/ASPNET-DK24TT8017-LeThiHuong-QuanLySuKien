<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Trường Đại Học Nghệ Thuật Tp.HCM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        /* [Giữ nguyên CSS của bạn tại đây] */
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            display: flex !important;
            flex-direction: column !important;
            background-color: #ffffff;
        }

        .body-content-wrapper {
            flex: 1 0 auto;
            margin-top: 120px;
        }

        footer.footer {
            flex-shrink: 0;
            position: relative !important;
            bottom: 0;
            width: 100%;
            background-color: #4e545a;
            border-top: 1px solid #e7e7e7;
            margin-top: 30px !important;
            display: flex !important;
            flex-direction: column !important;
            justify-content: center !important;
            align-items: center !important;
            height: 50px !important;
            padding: 0 !important;
        }

        .footer-text-line1 {
            font-weight: 500;
            color: #ffffff !important;
            margin-bottom: 0px !important;
            line-height: 1.2 !important;
            font-size: 13px;
        }

        .footer-text-line2 {
            color: #e9ecef !important;
            margin-bottom: 0 !important;
            line-height: 1.2 !important;
            font-size: 12px;
        }

        .btn-custom-auth {
            background-color: red !important;
            color: white !important;
            border: none;
            margin-left: 5px;
            font-size: 12px !important;
            font-weight: 500 !important;
            border-radius: 4px !important;
            transition: all 0.2s ease-in-out;
        }

            .btn-custom-auth:hover {
                background-color: darkred !important;
                color: #ffffff !important;
                text-decoration: none;
            }

        .navbar-nav .nav-item .nav-link {
            padding: 4px 15px !important;
            border-radius: 4px;
            transition: all 0.2s ease-in-out;
        }

            .navbar-nav .nav-item .nav-link:hover, .navbar-nav .nav-item.active .nav-link {
                background-color: #007bff !important;
                color: white !important;
            }

        .navbar-nav .nav-item.show .nav-link.dropdown-toggle {
            background-color: #007bff !important;
            color: white !important;
        }

        .dropdown-menu .dropdown-item {
            transition: all 0.15s ease-in-out;
        }

            .dropdown-menu .dropdown-item:hover {
                background-color: #007bff !important;
                color: white !important;
            }
    </style>
</head>

<body>
    <div class="container mt-4">
        <partial name="_Breadcrumb" />

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <header class="fixed-top box-shadow border-bottom bg-white">
        <nav class="navbar navbar-light bg-white" style="padding: 2px 0 !important;">
            <div class="container d-flex justify-content-between align-items-center">

                <a class="navbar-brand d-flex flex-column align-items-center text-center" asp-area="" asp-controller="Home" asp-action="Index" style="padding: 0; margin: 0;">
                    <div style="width: 28px; height: 40px; display: flex; justify-content: center; align-items: center; margin-bottom: 0px;">
                        <img src="~/HomeImage/Logo.jpg" alt="Logo Trường" style="max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain;" />
                    </div>
                    <div class="d-flex flex-column" style="margin-top: 1px;">
                        <span class="font-weight-bold text-dark" style="font-size: 10px; letter-spacing: 0.2px; line-height: 1.2 !important;">TRƯỜNG ĐẠI HỌC NGHỆ THUẬT</span>
                        <span class="text-muted font-weight-bold" style="font-size: 8px; letter-spacing: 0.2px; line-height: 1.2 !important; margin-top: 1px !important;">TP. HỒ CHÍ MINH</span>
                    </div>
                </a>

                <div class="form-inline">
                    @using Microsoft.AspNetCore.Http
                    @inject IHttpContextAccessor HttpContextAccessor

                    @{
                        var hoTen = HttpContextAccessor.HttpContext.Session.GetString("HoTenSV");
                    }

                    @if (!string.IsNullOrEmpty(hoTen))
                    {
                        <span class="text-dark font-weight-bold mr-3" style="font-size: 13px;">Xin chào, @hoTen</span>
                        <a asp-controller="DangNhap" asp-action="DangXuat" class="btn btn-secondary" style="padding: 4px 10px !important; font-size: 12px;">Đăng xuất</a>
                    }
                    else
                    {
                        <a asp-controller="DangNhap" asp-action="DangNhap" class="btn btn-custom-auth" style="padding: 4px 10px !important;">Đăng Nhập</a>
                      //  <a asp-controller="DangKy" asp-action="DangKy" class="btn btn-custom-auth" style="padding: 4px 10px !important;">Đăng Ký</a>
                    }
                </div>
            </div>
        </nav>

        <div style="background-color: #4e545a; border-top: 1px solid rgba(255,255,255,0.1);">
            <div class="container">
                <nav class="navbar navbar-expand navbar-dark p-0 d-flex justify-content-center">
                    <ul class="navbar-nav" style="padding: 3px 0 !important;">
                        <li class="nav-item">
                            <a class="nav-link text-white font-weight-bold" style="font-size: 13px;" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @* --- CODE KIỂM TRA ROLE (BẮT ĐẦU) --- *@
                        @{
                            var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
                        }

                        @if (role == "Admin")
                        {

                            <li class="nav-item dropdown ml-3">
                                <a class="nav-link dropdown-toggle text-white font-weight-bold" style="font-size: 13px;" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    Quản lý sự kiện
                                </a>

                                <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <a class="dropdown-item py-2" asp-controller="QuanLySK" asp-action="QuanLySK">Danh sách</a>
                                    <a class="dropdown-item py-2" asp-controller="Them" asp-action="ThemSK">Thêm mới</a>
                                    @*  <a class="dropdown-item py-2" asp-controller="DiemDanh" asp-action="DiemDanh">Điểm Danh</a>
                    <a class="dropdown-item py-2" href="#">Báo Cáo & Thống Kê</a> *@
                                </div>

                            </li>
                            <li class="nav-item ml-3">
                                <a class="nav-link text-white font-weight-bold" style="font-size: 13px;" asp-area="" asp-controller="QuanLyLoai" asp-action="Admin_LoaiSK">
                                    Phân loại sự kiện
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white font-weight-bold" style="font-size: 13px;" asp-controller="PhanCong" asp-action="Admin_PhanCong">Phân công</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white font-weight-bold" style="font-size: 13px;" asp-controller="ThongKe_Report" asp-action="ThongKe">Thống kê</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white font-weight-bold" style="font-size: 13px;" href="/ThongBao/Index">Thông báo</a>
                            </li>



                        }
                        else
                        {
                            <li class="nav-item dropdown ml-3">
                                <a class="nav-link dropdown-toggle text-white font-weight-bold" style="font-size: 13px;" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    Sự Kiện
                                </a>
                                <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <a class="dropdown-item py-2" asp-controller="Home" asp-action="Index_SuKien">Tất cả</a>
                                    
                                </div>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white font-weight-bold" style="font-size: 13px;" asp-area="" asp-controller="ThongKe_Report" asp-action="ThongKe">Thống kê-Báo cáo</a>
                            </li>
                            @if (!string.IsNullOrEmpty(hoTen))
                            {
                                // <li class="class="nav-item ml-3">
                                //      <a class="nav-link text-white font-weight-bold" style="font-size: 13px;" href="@Url.Action("Index", "myNoti")">Thông báo của tôi</a>
                                //  </li>
                                <li class="nav-item ml-3">
                                    <a class="nav-link text-white font-weight-bold" style="font-size: 13px;" asp-controller="MySK" asp-action="MySK">Sự kiện của tôi</a>
                                </li>
                            }
                        }
                        @* --- CODE KIỂM TRA ROLE (KẾT THÚC) --- *@


                    </ul>
                </nav>
            </div>
        </div>
    </header>

    <div class="container body-content-wrapper">
        <main role="main" class="pb-3">@RenderBody()</main>
    </div>

    <footer class="footer">
        <p class="footer-text-line1">Website đồ án được thiết kế bởi sinh viên Lê Thị Hương</p>
        <p class="footer-text-line2">Giáo viên hướng dẫn Đoàn Phước Miền</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>