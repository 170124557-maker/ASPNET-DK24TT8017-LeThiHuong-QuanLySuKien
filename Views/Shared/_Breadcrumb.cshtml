
<div class="breadcrumb-wrapper mt-3 mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            @if (ViewData["Breadcrumb"] is List<(string Title, string Url)> crumbs)
            {
                @foreach (var item in crumbs)
                {
                    <li class="breadcrumb-item @(item.Url == null ? "active" : "")">
                        @if (item.Url != null)
                        {
                            <a href="@item.Url">@item.Title</a>
                        }
                        else
                        {
                            @item.Title
                        }
                    </li>
                }
            }
        </ol>
    </nav>
    </div>
