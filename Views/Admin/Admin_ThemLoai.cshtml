@model DA09_QLSK.Models.PhanLoaiSK

@{
    ViewData["Title"] = "Thêm loại sự kiện";
}

<div class="container mt-4">
    <h2>Thêm Loại Sự Kiện Mới</h2>
    <hr />
    <form asp-action="Create" method="post">
        <div class="form-group mb-3">
            <label>Mã Loại SK</label>
            <input asp-for="MaLoaiSK" class="form-control" required placeholder="Ví dụ: LSK01" />
            <span asp-validation-for="MaLoaiSK" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Tên Loại Sự Kiện</label>
            <input asp-for="TenLoai" class="form-control" required />
        </div>

        <div class="form-group mb-3">
            <label>Mô tả</label>
            <textarea asp-for="MoTaLoaiSK" class="form-control" rows="4"></textarea>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Thêm mới</button>
            <a asp-action="Admin_LoaiSK" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>