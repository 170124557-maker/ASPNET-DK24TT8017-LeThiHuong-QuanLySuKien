@model IEnumerable<DA09_QLSK.Models.SuKien>

@{
    ViewData["Title"] = "Phân công công việc";
    ViewData["Breadcrumb"] = new List<(string Title, string Url)>
{
       
        ("Phân công", null)
    };
}

<div class="container mt-4">
    <partial name="_Breadcrumb" />
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Phân Công Công Việc</h2>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="thead-light">
            <tr>
                <th>Mã SK</th>
                <th>Tên sự kiện</th>
                <th>Ngày bắt đầu</th>
                <th>Địa điểm</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaSK</td>
                    <td>@item.TenSK</td>
                    <td>@item.start_date?.ToString("dd/MM/yyyy")</td>
                    <td>@item.DiaDiem</td>
                    <td>
                        <a asp-controller="PhanCong" asp-action="ChiTietPhanCong" asp-route-id="@item.MaSK"
                           class="btn btn-sm btn-info">
                            <i class="fas fa-tasks"></i> Phân công
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>