@model DA09_QLSK.Models.PhanLoaiSK

@{
    ViewData["Title"] = "Sửa loại sự kiện";
}

<div class="container mt-4">
    <h2>Sửa Loại Sự Kiện</h2>
    <hr />
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="MaLoaiSK" /> <div class="form-group mb-3">
            <label>Tên Loại Sự Kiện</label>
            <input asp-for="TenLoai" class="form-control" required />
        </div>

        <div class="form-group mb-3">
            <label>Mô tả</label>
            <textarea asp-for="MoTaLoaiSK" class="form-control" rows="4"></textarea>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a asp-action="Admin_LoaiSK" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>