@model IEnumerable<DA09_QLSK.Models.ThongKe_Report>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Thống Kê-Report";
    ViewData["Breadcrumb"] = new List<(string Title, string Url)>
{
        ("Thống Kê-Report", null)
    };
}

<partial name="~/Views/Shared/_Breadcrumb.cshtml" />

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8">
            <h2 class="text-primary font-weight-bold">Dashboard Thống kê</h2>
            <p class="text-muted">Chọn các điều kiện bên dưới để lọc danh sách sự kiện</p>
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form asp-action="ThongKe" method="get">
                        <div class="row align-items-end">
                            <div class="col-md-4">
                                <label>Chọn Khoa:</label>
                                <select name="khoa" class="form-control" onchange="this.form.submit()">
                                    <option value="">-- Tất cả --</option>
                                    @if (ViewBag.KhoaList != null)
                                    {
                                        foreach (var k in (List<DA09_QLSK.Models.Khoa>)ViewBag.KhoaList)
                                        {
                                            <option value="@k.MaKhoa" selected="@(ViewBag.SelectedKhoa == k.MaKhoa)">@k.TenKhoa</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label>Trạng thái:</label>
                                <select name="trangThai" class="form-control" onchange="this.form.submit()">
                                    <option value="">-- Tất cả --</option>
                                    @if (ViewBag.TrangThaiList != null)
                                    {
                                        foreach (var tt in (List<string>)ViewBag.TrangThaiList)
                                        {
                                            <option value="@tt" selected="@(ViewBag.SelectedTrangThai == tt)">@tt</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label>Lĩnh vực:</label>
                                <select name="loaiSK" class="form-control" onchange="this.form.submit()">
                                    <option value="">-- Tất cả --</option>
                                    @if (ViewBag.LoaiSKList != null)
                                    {
                                        foreach (var item in (List<DA09_QLSK.Models.PhanLoaiSK>)ViewBag.LoaiSKList)
                                        {
                                            <option value="@item.MaLoaiSK" selected="@(ViewBag.SelectedLoaiSK == item.MaLoaiSK)">@item.TenLoai</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-12 text-end">
                                <a asp-action="ThongKe" class="btn btn-secondary px-4">Reset</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm p-2 h-100">
                <h6 class="text-center font-weight-bold">Tỷ lệ sự kiện theo Khoa</h6>
                <div style="height: 200px; width: 100%;">
                    <canvas id="myChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3 mt-2">
        <div class="text-start">
            <span class="fs-6"><strong>Tổng số sự kiện: @ViewBag.TotalItems</strong></span>
        </div>
        @{ string userRole = Context.Session.GetString("Role"); }
        @if (userRole == "Admin")
        {
            <div class="text-end">
                <a href="@Url.Action("ExportExcel", new { khoa = ViewBag.SelectedKhoa, trangThai = ViewBag.SelectedTrangThai, loaiSK = ViewBag.SelectedLoaiSK })"
                   class="btn btn-success">Xuất Excel</a>
            </div>
        }
    </div>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>STT</th>
                <th>Tên sự kiện</th>
                <th>Lĩnh vực</th>
                <th>Khoa</th>
                <th>Thời gian</th>
                <th>Đăng ký</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @{ int stt = (ViewBag.CurrentPage - 1) * 10 + 1; }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(stt++)</td>
                    <td>@item.TenSK</td>
                    <td>@item.TenLoai</td>
                    <td>@item.TenKhoa</td>
                    <td>
                        @(item.start_date?.ToString("dd/MM/yyyy")) @(item.Start_time?.ToString(@"hh\:mm"))
                        - @(item.end_date?.ToString("dd/MM/yyyy")) @(item.End_time?.ToString(@"hh\:mm"))
                    </td>
                    <td>@item.SoLuongDK / @(item.SoLuongGioiHan ?? 0)</td>
                    <td>@item.TrangThai</td>
                </tr>
            }
        </tbody>
    </table>

    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("ThongKe", new { page = i, khoa = ViewBag.SelectedKhoa, trangThai = ViewBag.SelectedTrangThai, loaiSK = ViewBag.SelectedLoaiSK })">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    var ctx = document.getElementById('myChart').getContext('2d');
    var chartData = @Html.Raw(Json.Serialize(ViewBag.ChartData));
    new Chart(ctx, {
        type: 'pie',
        data: {
            labels: chartData.map(item => item.tenKhoa),
            datasets: [{
                data: chartData.map(item => item.soLuong),
                backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            layout: { padding: 0 },
            plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } }
            }
        }
    });
</script>